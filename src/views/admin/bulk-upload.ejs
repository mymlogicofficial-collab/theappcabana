    let productCount = 0;
    const maxProducts = 10;

    function switchTab(tab) {
      // Hide all tabs
      document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
      document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
      
      // Show selected tab
      document.getElementById(tab).classList.add('active');
      event.target.classList.add('active');
    }

    function addProduct() {
      if (productCount >= maxProducts) {
        alert(`Maximum ${maxProducts} products at once`);
        return;
      }

      const container = document.getElementById('products-container');
      const id = productCount++;

      const html = `
        <div class="product-item" id="product-${id}">
          <div class="product-field">
            <label>Title *</label>
            <input type="text" name="products[${id}][title]" required>
          </div>
          <div class="product-field">
            <label>Description</label>
            <input type="text" name="products[${id}][description]">
          </div>
          <div class="product-field">
            <label>Type *</label>
            <select name="products[${id}][type]" required>
              <option value="app">App</option>
              <option value="music">Music</option>
              <option value="art">Digital Art</option>
            </select>
          </div>
          <div class="product-field">
            <label>Price *</label>
            <input type="number" name="products[${id}][price]" step="0.01" min="0.99" required>
          </div>
          <div style="display: flex; gap: 10px; align-items: flex-end;">
            <div class="product-field" style="flex: 1;">
              <label>Files</label>
              <input type="file" name="products[${id}][files][]" multiple>
            </div>
            <button type="button" onclick="removeProduct(${id})" class="remove-btn">Remove</button>
          </div>
        </div>
      `;
      
      container.insertAdjacentHTML('beforeend', html);
    }

    function removeProduct(id) {
      const element = document.getElementById(`product-${id}`);
      if (element) element.remove();
    }

    // Add first product on load
    window.addEventListener('DOMContentLoaded', () => {
      addProduct();
    });
  </script>
</body>
</html>

