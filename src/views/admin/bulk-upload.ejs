<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bulk Upload - The App Cabana</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0a0e27; color: #fff; }
    .header { padding: 20px 40px; background: #1a1f3a; border-bottom: 1px solid #333; }
    .back-btn { display: inline-flex; align-items: center; gap: 8px; color: #667eea; text-decoration: none; font-weight: 500; margin-bottom: 20px; }
    .back-btn:hover { color: #7c8ff7; }
    .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
    h1 { margin-bottom: 30px; font-size: 28px; }
    .form-section { background: #1a1f3a; padding: 30px; border-radius: 8px; border: 1px solid #333; margin-bottom: 30px; }
    label { display: block; margin-top: 15px; margin-bottom: 8px; font-weight: 600; font-size: 14px; }
    input, select, textarea { 
      width: 100%; 
      padding: 12px; 
      background: #0a0e27; 
      border: 1px solid #333; 
      color: #fff; 
      border-radius: 4px; 
      font-family: inherit;
      box-sizing: border-box;
    }
    input:focus, select:focus, textarea:focus { 
      outline: none; 
      border-color: #667eea; 
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    textarea { resize: vertical; min-height: 100px; }
    .btn { 
      display: inline-block;
      padding: 12px 30px; 
      background: #667eea; 
      color: #fff; 
      border: none;
      border-radius: 6px; 
      cursor: pointer; 
      font-weight: 600;
      font-size: 15px;
    }
    .btn:hover { background: #5568d3; }
    .btn-secondary { background: #2a3050; }
    .btn-secondary:hover { background: #3a4050; }
    .btn-danger { background: #d9534f; }
    .btn-danger:hover { background: #c9423f; }
    
    .products-list { margin-top: 30px; }
    .product-item { 
      background: #0a0e27; 
      padding: 20px; 
      border-radius: 6px; 
      border: 1px solid #333;
      margin-bottom: 15px;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 100px;
      gap: 15px;
      align-items: center;
    }
    .product-field { }
    .product-field label { font-size: 12px; color: #999; margin: 0 0 5px 0; }
    .product-field input, .product-field select { margin: 0; }
    .remove-btn { 
      padding: 8px 15px; 
      background: #d9534f; 
      color: #fff; 
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: 500;
      align-self: flex-end;
    }
    .remove-btn:hover { background: #c9423f; }
    
    .upload-section { margin-top: 30px; }
    .file-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); 
      gap: 15px;
      margin-top: 20px;
    }
    .file-input-wrapper { 
      background: #0a0e27;
      border: 2px dashed #333;
      border-radius: 6px;
      padding: 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s;
    }
    .file-input-wrapper:hover { 
      border-color: #667eea;
      background: #1a1f3a;
    }
    .file-input-wrapper input { display: none; }
    .file-input-label { 
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    .file-icon { font-size: 24px; }
    
    .buttons { 
      display: flex; 
      gap: 15px; 
      margin-top: 30px; 
      justify-content: center;
    }
    .success { color: #51cf66; background: rgba(81, 207, 102, 0.1); padding: 12px; border-radius: 4px; margin-bottom: 20px; }
    .error { color: #ff6b6b; background: rgba(255, 107, 107, 0.1); padding: 12px; border-radius: 4px; margin-bottom: 20px; }
    .info { font-size: 13px; color: #999; margin-top: 5px; }
    small { color: #999; font-size: 12px; display: block; margin-top: 5px; }
    
    .tabs { display: flex; gap: 0; margin-bottom: 20px; border-bottom: 1px solid #333; }
    .tab { 
      padding: 15px 20px; 
      background: transparent; 
      border: none; 
      color: #999; 
      cursor: pointer;
      font-weight: 500;
      border-bottom: 2px solid transparent;
      transition: all 0.3s;
    }
    .tab.active { 
      color: #667eea; 
      border-bottom-color: #667eea;
    }
    .tab:hover { color: #fff; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
  </style>
</head>
<body>
  <div class="header">
    <a href="/admin/dashboard" class="back-btn">← Back to Dashboard</a>
  </div>

  <div class="container">
    <h1>📦 Bulk Upload Products</h1>
    
    <% if (success) { %>
      <div class="success">✓ <%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="error">✗ <%= error %></div>
    <% } %>

    <div class="tabs">
      <button class="tab active" onclick="switchTab('csv')">📄 CSV Upload</button>
      <button class="tab" onclick="switchTab('manual')">✏️ Manual Entry</button>
    </div>

    <!-- CSV Upload Tab -->
    <div id="csv" class="tab-content active">
      <div class="form-section">
        <h2>Upload CSV File</h2>
        <p style="color: #aaa; margin-bottom: 20px;">Upload a CSV with columns: title, description, price, type, category (optional)</p>
        
        <form method="POST" action="/admin/bulk/upload-csv" enctype="multipart/form-data">
          <label>CSV File *</label>
          <input type="file" name="csv" accept=".csv" required>
          <small>Format: title, description, price, type</small>
          
          <label style="margin-top: 20px;">Cover Images (ZIP with images named like products) *</label>
          <input type="file" name="images" accept=".zip" required>
          <small>ZIP file with image files (JPG, PNG, GIF, WebP)</small>
          
          <button type="submit" class="btn" style="margin-top: 20px;">Upload CSV & Images</button>
        </form>
      </div>
    </div>

    <!-- Manual Entry Tab -->
    <div id="manual" class="tab-content">
      <form method="POST" action="/admin/bulk/upload-manual" enctype="multipart/form-data">
        <div class="form-section">
          <h2>Add Products One by One</h2>
          <p style="color: #aaa; margin-bottom: 20px;">Add up to 10 products at once</p>
          
          <div id="products-container">
            <!-- Products will be added here -->
          </div>
          
          <button type="button" onclick="addProduct()" class="btn btn-secondary" style="margin-top: 20px;">+ Add Product</button>
          
          <div class="buttons" style="margin-top: 30px;">
            <button type="submit" class="btn">Upload All Products</button>
            <a href="/admin/dashboard" class="btn btn-secondary" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">Cancel</a>
          </div>
        </div>
      </form>
    </div>
  </div>

  <script>
    let productCount = 0;
    const maxProducts = 10;

    function switchTab(tab) {
      // Hide all tabs
      document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
      document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
      
      // Show selected tab
      document.getElementById(tab).classList.add('active');
      event.target.classList.add('active');
    }

    function addProduct() {
      if (productCount >= maxProducts) {
        alert(`Maximum ${maxProducts} products at once`);
        return;
      }

      const container = document.getElementById('products-container');
      const id = productCount++;

      const html = `
        <div class="product-item" id="product-${id}">
          <div class="product-field">
            <label>Title *</label>
            <input type="text" name="products[${id}][title]" required>
          </div>
          <div class="product-field">
            <label>Description</label>
            <input type="text" name="products[${id}][description]">
          </div>
          <div class="product-field">
            <label>Type *</label>
            <select name="products[${id}][type]" required>
              <option value="app">App</option>
              <option value="music">Music</option>
              <option value="art">Digital Art</option>
            </select>
          </div>
          <div class="product-field">
            <label>Price *</label>
            <input type="number" name="products[${id}][price]" step="0.01" min="0.99" required>
          </div>
          <div style="display: flex; gap: 10px; align-items: flex-end;">
            <div class="product-field" style="flex: 1;">
              <label>Files</label>
              <input type="file" name="products[${id}][files][]" multiple>
            </div>
            <button type="button" onclick="removeProduct(${id})" class="remove-btn">Remove</button>
          </div>
        </div>
      `;
      
      container.insertAdjacentHTML('beforeend', html);
    }

    function removeProduct(id) {
      const element = document.getElementById(`product-${id}`);
      if (element) element.remove();
    }

    // Add first product on load
    window.addEventListener('DOMContentLoaded', () => {
      addProduct();
    });
  </script>
</body>
</html>

