    const tabs = document.querySelectorAll('.tab-btn');
    const panes = document.querySelectorAll('.tab-pane');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        panes.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.tab).classList.add('active');
      });
    });

    // CSV drag & drop
    const csvBox = document.getElementById('csv-box');
    const csvFile = document.getElementById('csv-file');
    csvBox.addEventListener('click', () => csvFile.click());
    csvBox.addEventListener('dragover', e => { e.preventDefault(); csvBox.classList.add('dragover'); });
    csvBox.addEventListener('dragleave', () => csvBox.classList.remove('dragover'));
    csvBox.addEventListener('drop', e => {
      e.preventDefault();
      csvBox.classList.remove('dragover');
      csvFile.files = e.dataTransfer.files;
      uploadCSV();
    });
    csvFile.addEventListener('change', uploadCSV);

    // JSON drag & drop
    const jsonBox = document.getElementById('json-box');
    const jsonFile = document.getElementById('json-file');
    jsonBox.addEventListener('click', () => jsonFile.click());
    jsonBox.addEventListener('dragover', e => { e.preventDefault(); jsonBox.classList.add('dragover'); });
    jsonBox.addEventListener('dragleave', () => jsonBox.classList.remove('dragover'));
    jsonBox.addEventListener('drop', e => {
      e.preventDefault();
      jsonBox.classList.remove('dragover');
      jsonFile.files = e.dataTransfer.files;
      uploadJSON();
    });
    jsonFile.addEventListener('change', uploadJSON);

    // Files drag & drop
    const filesBox = document.getElementById('files-box');
    const filesInput = document.getElementById('files-input');
    filesBox.addEventListener('click', () => filesInput.click());
    filesBox.addEventListener('dragover', e => { e.preventDefault(); filesBox.classList.add('dragover'); });
    filesBox.addEventListener('dragleave', () => filesBox.classList.remove('dragover'));
    filesBox.addEventListener('drop', e => {
      e.preventDefault();
      filesBox.classList.remove('dragover');
      filesInput.files = e.dataTransfer.files;
    });

    async function uploadCSV() {
      if (!csvFile.files[0]) return;
      const formData = new FormData();
      formData.append('csv', csvFile.files[0]);
      await postBulk('/admin/bulk/csv', formData);
    }

    async function uploadJSON() {
      if (!jsonFile.files[0]) return;
      const formData = new FormData();
      formData.append('json', jsonFile.files[0]);
      await postBulk('/admin/bulk/json', formData);
    }

    function uploadFiles() {
      if (!filesInput.files.length) return alert('No files selected');
      const formData = new FormData();
      for (let file of filesInput.files) formData.append('files', file);
      formData.append('products', document.getElementById('files-metadata').value);
      postBulk('/admin/bulk/files', formData);
    }

    async function postBulk(url, formData) {
      try {
        const resp = await fetch(url, { method: 'POST', body: formData });
        const data = await resp.json();
        showResults(data);
      } catch (e) {
        alert('Upload failed: ' + e.message);
      }
    }

    function showResults(data) {
      const results = document.getElementById('results');
      document.getElementById('success-count').textContent = data.success || 0;
      document.getElementById('failed-count').textContent = data.failed || 0;
      document.getElementById('total-count').textContent = (data.success || 0) + (data.failed || 0);
      
      const errorsList = document.getElementById('errors-list');
      errorsList.innerHTML = '';
      if (data.errors && data.errors.length > 0) {
        data.errors.forEach(err => {
          const div = document.createElement('div');
          div.className = 'result-item result-error';
          div.textContent = err;
          errorsList.appendChild(div);
        });
      }
      results.classList.add('show');
    }
  </script>
