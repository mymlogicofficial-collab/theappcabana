  <div class="container">
    <h1 class="page-title">Dashboard</h1>
    
    <div class="action-bar">
      <a href="/admin/upload" class="btn">+ Upload Digital Product</a>
      <a href="/admin/upload-physical" class="btn" style="background: #764ba2;">+ Upload Physical Product</a>
    </div>

    <h2 class="section-title">Your Products</h2>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">📦</div>
        <div class="empty-state-text">No products yet. Upload your first product to get started!</div>
        <a href="/admin/upload" class="btn">Upload Product</a>
      </div>
    <% } else { %>
      <div class="products-grid">
        <% products.forEach(p => { %>
          <div class="product-card">
            <div class="product-thumb">
              <% if (p.cover_url) { %>
                <img src="<%= p.cover_url %>" alt="<%= p.title %>">
              <% } else { %>
                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #666;">No Image</div>
              <% } %>
            </div>
            <div class="product-info">
              <span class="product-type"><%= p.type.toUpperCase() %></span>
              <h3 class="product-title"><%= p.title %></h3>
              <div class="product-price">$<%= (p.price_cents / 100).toFixed(2) %></div>
              <div class="product-stats">
                <%= p.download_count %> downloads
              </div>
              <div class="product-status <%= p.is_approved ? 'status-live' : 'status-pending' %>">
                <%= p.is_approved ? '✓ Live' : '⏳ Pending Approval' %>
              </div>
              <div class="product-actions">
                <a href="/shop/product/<%= p.slug %>" class="action-view">View</a>
                <a href="/admin/edit/<%= p.id %>" class="action-edit">Edit</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>

