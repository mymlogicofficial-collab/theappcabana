<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - The App Cabana</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0a0e27; color: #fff; }
    .header { padding: 20px 40px; background: #1a1f3a; border-bottom: 1px solid #333; }
    .back-btn { display: inline-flex; align-items: center; gap: 8px; color: #667eea; text-decoration: none; font-weight: 500; margin-bottom: 20px; }
    .back-btn:hover { color: #7c8ff7; }
    .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }
    .page-title { font-size: 32px; margin-bottom: 30px; }
    .btn { display: inline-block; padding: 12px 30px; background: #667eea; color: #fff; text-decoration: none; border-radius: 6px; font-weight: 500; }
    .btn:hover { background: #5568d3; }
    .action-bar { display: flex; gap: 15px; margin-bottom: 30px; flex-wrap: wrap; }
    .section-title { font-size: 18px; margin-bottom: 20px; font-weight: 600; }
    
    .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 20px; }
    .product-card { background: #1a1f3a; border: 1px solid #333; border-radius: 8px; overflow: hidden; }
    .product-thumb { width: 100%; height: 200px; background: #0a0e27; overflow: hidden; }
    .product-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .product-info { padding: 20px; }
    .product-title { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
    .product-type { display: inline-block; font-size: 11px; background: #2a3050; padding: 4px 10px; border-radius: 3px; margin-bottom: 10px; }
    .product-price { font-size: 18px; font-weight: 700; color: #667eea; margin-bottom: 10px; }
    .product-stats { font-size: 12px; color: #999; margin-bottom: 15px; }
    .product-status { 
      padding: 6px 12px; 
      border-radius: 4px; 
      font-size: 12px; 
      font-weight: 500;
      display: inline-block;
      margin-bottom: 15px;
    }
    .status-live { background: rgba(81, 207, 102, 0.2); color: #51cf66; }
    .status-pending { background: rgba(255, 193, 7, 0.2); color: #ffc107; }
    
    .product-actions { display: flex; gap: 10px; }
    .product-actions a, .product-actions button { 
      flex: 1; 
      padding: 8px 12px; 
      border: none; 
      border-radius: 4px; 
      font-size: 13px; 
      font-weight: 500; 
      text-decoration: none; 
      cursor: pointer;
      text-align: center;
    }
    .action-view { background: #2a3050; color: #667eea; }
    .action-view:hover { background: #3a4050; }
    .action-edit { background: #667eea; color: #fff; }
    .action-edit:hover { background: #5568d3; }
    .action-delete { background: #d9534f; color: #fff; }
    .action-delete:hover { background: #c9423f; }
    
    .empty-state { text-align: center; padding: 60px 20px; }
    .empty-state-icon { font-size: 48px; margin-bottom: 20px; }
    .empty-state-text { color: #999; margin-bottom: 30px; }
  </style>
</head>
<body>
