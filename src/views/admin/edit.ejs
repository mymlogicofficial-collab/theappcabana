<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Product - The App Cabana</title>
  <style>
    body { font-family: sans-serif; background: #0a0e27; color: #fff; }
    .container { max-width: 600px; margin: 0 auto; padding: 40px; }
    .form { background: #1a1f3a; padding: 40px; border-radius: 8px; border: 1px solid #333; }
    h1 { margin-bottom: 30px; color: #667eea; }
    label { display: block; margin-top: 15px; margin-bottom: 5px; font-weight: bold; }
    input, select, textarea { width: 100%; padding: 10px; background: #0a0e27; border: 1px solid #333; color: #fff; border-radius: 4px; margin-top: 5px; }
    textarea { resize: vertical; }
    button { width: 100%; margin-top: 20px; padding: 12px; background: #667eea; border: none; color: #fff; border-radius: 4px; cursor: pointer; font-size: 16px; }
    button:hover { background: #764ba2; }
    .error { color: #ff6b6b; margin-bottom: 20px; }
    .back-btn { color: #667eea; text-decoration: none; margin-bottom: 20px; display: inline-block; }
    .back-btn:hover { color: #7c8ff7; }
  </style>
</head>
<body>
  <div class="container">
    <a href="/admin/dashboard" class="back-btn">← Back to Dashboard</a>
    <div class="form">
      <h1>Edit Product</h1>
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <form method="POST" enctype="multipart/form-data">
        <label>Product Type</label>
        <input type="text" value="<%= product.type %>" disabled style="opacity: 0.6;">

        <label>Title *</label>
        <input type="text" name="title" value="<%= product.title %>" required>

        <label>Description</label>
        <textarea name="description" rows="4"><%= product.description || '' %></textarea>

        <label>Price (USD) *</label>
        <input type="number" name="price" step="0.99" min="0" value="<%= (product.price_cents / 100).toFixed(2) %>" required>

        <label>Replace File (Optional)</label>
        <input type="file" name="file">
        <p style="color: #999; font-size: 12px; margin-top: 5px;">Leave blank to keep current file</p>

        <button type="submit">Update Product</button>
      </form>
    </div>
  </div>
</body>
</html>
