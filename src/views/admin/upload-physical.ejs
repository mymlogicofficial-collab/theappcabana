<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload Physical Product - The App Cabana</title>
  <style>
    body { font-family: sans-serif; background: #0a0e27; color: #fff; padding: 40px; }
    .container { max-width: 600px; margin: 0 auto; }
    h1 { color: #667eea; margin-bottom: 30px; }
    .form-group { margin-bottom: 20px; }
    label { display: block; margin-bottom: 8px; font-weight: bold; }
    input, select, textarea { 
      width: 100%; 
      padding: 10px; 
      background: #1a1f3a; 
      border: 1px solid #333; 
      color: #fff; 
      border-radius: 4px; 
      font-family: sans-serif;
      box-sizing: border-box;
    }
    textarea { resize: vertical; min-height: 100px; }
    .btn { 
      background: #667eea; 
      color: #fff; 
      padding: 12px 30px; 
      border: none; 
      border-radius: 4px; 
      cursor: pointer; 
      font-size: 16px;
      width: 100%;
    }
    .btn:hover { background: #5568d3; }
    .back-link { color: #667eea; text-decoration: none; margin-bottom: 20px; display: block; }
    .back-link:hover { text-decoration: underline; }
    .error { background: #2a1a1a; color: #ff6b6b; padding: 10px; border-radius: 4px; margin-bottom: 20px; }
    .info { background: #1a2a3a; color: #aaa; padding: 10px; border-radius: 4px; margin-bottom: 20px; font-size: 14px; }
    .variants-section { background: #1a1f3a; padding: 15px; border-radius: 4px; margin-top: 10px; max-height: 250px; overflow-y: auto; }
    .variant-item { margin-bottom: 10px; }
    .variant-item input { margin-right: 8px; width: auto; display: inline-block; }
    .variant-item label { display: inline; margin-bottom: 0; margin-left: 5px; font-size: 14px; }
    .variant-item small { display: block; margin-left: 24px; color: #999; font-size: 12px; }
  </style>
</head>
<body>
  <div class="container">
    <a href="/admin/upload" class="back-link">← Back to Digital Upload</a>
    
    <h1>Upload Physical Product to Printful</h1>
    <p style="color: #aaa; margin-bottom: 20px;">Design will be synced to Printful automatically for on-demand printing</p>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <div class="info">
      💡 Upload design image. Select product type (shirt, mug, hat, etc.). Choose which size/color variants to offer. We'll sync to Printful and handle fulfillment.
    </div>

    <form method="POST" action="/admin/upload-physical" enctype="multipart/form-data">
      
      <div class="form-group">
        <label for="title">Product Title *</label>
        <input type="text" id="title" name="title" required placeholder="e.g., Cool Band Tee Design">
      </div>

      <div class="form-group">
        <label for="category">Product Type *</label>
        <select id="category" name="category" required onchange="loadVariants()">
          <option value="">-- Select Product Type --</option>
          <option value="t-shirts">T-Shirts</option>
          <option value="hoodies">Hoodies</option>
          <option value="mugs">Mugs</option>
          <option value="hats">Hats</option>
          <option value="phone-cases">Phone Cases</option>
          <option value="pillows">Throw Pillows</option>
          <option value="blankets">Throw Blankets</option>
          <option value="stickers">Stickers</option>
        </select>
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" placeholder="Product description..."></textarea>
      </div>

      <div class="form-group">
        <label for="price">Your Selling Price ($) *</label>
        <input type="number" id="price" name="price" step="0.01" min="0" required placeholder="10.00">
        <small style="color: #aaa; margin-top: 5px; display: block;">Price you want to sell at. Printful cost added on top, you keep the margin.</small>
      </div>

      <div class="form-group">
        <label for="design">Design Image *</label>
        <input type="file" id="design" name="design" accept="image/*" required>
        <small style="color: #aaa; margin-top: 5px; display: block;">Design for the product (will be the cover/thumbnail)</small>
      </div>

      <div id="variants-loading" style="display: none; color: #aaa; text-align: center; padding: 20px;">
        Loading variants from Printful...
      </div>

      <div id="variants-section" class="form-group" style="display: none;">
        <label>Available Variants (Select which to offer) *</label>
        <div id="variants-list" class="variants-section">
          <!-- Populated by JavaScript -->
        </div>
      </div>

      <button type="submit" class="btn">Add to Printful Catalog & Save</button>
    </form>
  </div>

  <script>
    async function loadVariants() {
      const category = document.getElementById('category').value;
      if (!category) return;

      document.getElementById('variants-loading').style.display = 'block';
      document.getElementById('variants-section').style.display = 'none';

      try {
        const response = await fetch(`/api/printful/variants/${category}`);
        const data = await response.json();

        if (data.variants && data.variants.length > 0) {
          const variantsList = document.getElementById('variants-list');
          variantsList.innerHTML = '';

          data.variants.forEach(variant => {
            const div = document.createElement('div');
            div.className = 'variant-item';
            div.innerHTML = `
              <input type="checkbox" name="variants" value="${variant.id}" id="variant-${variant.id}" checked>
              <label for="variant-${variant.id}"><strong>${variant.name}</strong></label>
              <small>Stock: ${variant.in_stock ? '✓ Available' : '✗ Out of stock'}</small>
            `;
            variantsList.appendChild(div);
          });

          document.getElementById('variants-section').style.display = 'block';
          document.getElementById('variants-loading').style.display = 'none';
        } else {
          document.getElementById('variants-loading').innerHTML = '❌ No variants found for this product type';
        }
      } catch (err) {
        console.error('Error loading variants:', err);
        document.getElementById('variants-loading').innerHTML = '❌ Failed to load variants';
      }
    }
  </script>
</body>
</html>

