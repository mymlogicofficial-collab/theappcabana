<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload Physical Product - The App Cabana</title>
  <style>
    body { font-family: sans-serif; background: #0a0e27; color: #fff; padding: 40px; }
    .container { max-width: 600px; margin: 0 auto; }
    h1 { color: #667eea; margin-bottom: 30px; }
    .form-group { margin-bottom: 20px; }
    label { display: block; margin-bottom: 8px; font-weight: bold; }
    input, select, textarea { 
      width: 100%; 
      padding: 10px; 
      background: #1a1f3a; 
      border: 1px solid #333; 
      color: #fff; 
      border-radius: 4px; 
      font-family: sans-serif;
      box-sizing: border-box;
    }
    textarea { resize: vertical; min-height: 100px; }
    .btn { 
      background: #667eea; 
      color: #fff; 
      padding: 12px 30px; 
      border: none; 
      border-radius: 4px; 
      cursor: pointer; 
      font-size: 16px;
      width: 100%;
    }
    .btn:hover { background: #5568d3; }
    .back-link { color: #667eea; text-decoration: none; margin-bottom: 20px; display: block; }
    .back-link:hover { text-decoration: underline; }
    .error { background: #2a1a1a; color: #ff6b6b; padding: 10px; border-radius: 4px; margin-bottom: 20px; }
    .info { background: #1a2a3a; color: #aaa; padding: 10px; border-radius: 4px; margin-bottom: 20px; font-size: 14px; }
    .variants-section { background: #1a1f3a; padding: 15px; border-radius: 4px; margin-top: 10px; }
    .variant-column { display: inline-block; width: 48%; vertical-align: top; margin-right: 2%; }
    .variant-column:last-child { margin-right: 0; }
    .variant-item { margin-bottom: 10px; }
    .variant-item input { margin-right: 8px; width: auto; display: inline-block; }
    .variant-item label { display: inline; margin-bottom: 0; margin-left: 5px; }
  </style>
</head>
<body>
  <div class="container">
    <a href="/admin/upload" class="back-link">← Back to Digital Upload</a>
    
    <h1>Upload Physical Product to Zazzle</h1>
    <p style="color: #aaa; margin-bottom: 20px;">Design will be synced to Zazzle catalog automatically</p>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <div class="info">
      💡 Upload your design/mockup image. Select product type, colors, and sizes. We'll sync to Zazzle and handle fulfillment.
    </div>

    <form method="POST" action="/admin/upload-physical" enctype="multipart/form-data">
      
      <div class="form-group">
        <label for="title">Product Title *</label>
        <input type="text" id="title" name="title" required placeholder="e.g., Cool Band Tee Design">
      </div>

      <div class="form-group">
        <label for="category">Product Type *</label>
        <select id="category" name="category" required>
          <option value="">-- Select Product Type --</option>
          <option value="t-shirts">T-Shirts</option>
          <option value="hoodies">Hoodies</option>
          <option value="mugs">Mugs (11oz)</option>
          <option value="hats">Baseball Caps</option>
          <option value="phone-cases">Phone Cases</option>
          <option value="pillows">Throw Pillows</option>
          <option value="blankets">Throw Blankets</option>
          <option value="stickers">Stickers (4x4)</option>
        </select>
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" placeholder="Product description..."></textarea>
      </div>

      <div class="form-group">
        <label for="price">Your Selling Price ($) *</label>
        <input type="number" id="price" name="price" step="0.01" min="0" required placeholder="10.00">
        <small style="color: #aaa; margin-top: 5px; display: block;">Price you want to sell at. Zazzle cost added on top, you keep the margin.</small>
      </div>

      <div class="form-group">
        <label for="design">Design Image/Mockup *</label>
        <input type="file" id="design" name="design" accept="image/*" required>
        <small style="color: #aaa; margin-top: 5px; display: block;">This will be the product cover image on Zazzle</small>
      </div>

      <div class="form-group">
        <label>Available Colors *</label>
        <div class="variants-section">
          <div class="variant-item">
            <input type="checkbox" name="colors" value="black" id="color-black" checked>
            <label for="color-black">Black</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="colors" value="white" id="color-white" checked>
            <label for="color-white">White</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="colors" value="red" id="color-red">
            <label for="color-red">Red</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="colors" value="blue" id="color-blue">
            <label for="color-blue">Blue</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="colors" value="green" id="color-green">
            <label for="color-green">Green</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="colors" value="gray" id="color-gray">
            <label for="color-gray">Gray</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="colors" value="navy" id="color-navy">
            <label for="color-navy">Navy</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="colors" value="purple" id="color-purple">
            <label for="color-purple">Purple</label>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label>Available Sizes *</label>
        <div class="variants-section">
          <div class="variant-item">
            <input type="checkbox" name="sizes" value="xs" id="size-xs">
            <label for="size-xs">XS</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="sizes" value="s" id="size-s" checked>
            <label for="size-s">Small</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="sizes" value="m" id="size-m" checked>
            <label for="size-m">Medium</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="sizes" value="l" id="size-l" checked>
            <label for="size-l">Large</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="sizes" value="xl" id="size-xl">
            <label for="size-xl">XL</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="sizes" value="xxl" id="size-xxl">
            <label for="size-xxl">XXL</label>
          </div>
          <div class="variant-item">
            <input type="checkbox" name="sizes" value="3xl" id="size-3xl">
            <label for="size-3xl">3XL</label>
          </div>
        </div>
      </div>

      <button type="submit" class="btn">Add to Zazzle Catalog & Save</button>
    </form>
  </div>
</body>
</html>

