<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload - The App Cabana</title>
  <style>
    body { font-family: sans-serif; background: #0a0e27; color: #fff; }
    .container { max-width: 600px; margin: 0 auto; padding: 40px; }
    .form { background: #1a1f3a; padding: 40px; border-radius: 8px; border: 1px solid #333; }
    h1 { margin-bottom: 30px; }
    label { display: block; margin-top: 15px; margin-bottom: 5px; font-weight: bold; }
    input, select, textarea { width: 100%; padding: 10px; background: #0a0e27; border: 1px solid #333; color: #fff; border-radius: 4px; margin-top: 5px; box-sizing: border-box; }
    button { width: 100%; margin-top: 20px; padding: 12px; background: #667eea; border: none; color: #fff; border-radius: 4px; cursor: pointer; font-size: 16px; }
    button:hover { background: #764ba2; }
    .error { color: #ff6b6b; margin-bottom: 20px; }
    .preview { margin-top: 10px; max-width: 200px; border-radius: 4px; display: none; }
    .form-group { margin-bottom: 20px; }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="container">
    <div class="form">
      <h1>Upload New Product</h1>
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <form method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label>Product Type *</label>
          <select name="type" required>
            <option>Select type...</option>
            <option value="app">App</option>
            <option value="music">Music</option>
            <option value="art">Digital Art</option>
          </select>
        </div>

        <div class="form-group">
          <label>Title *</label>
          <input type="text" name="title" required>
        </div>

        <div class="form-group">
          <label>Description</label>
          <textarea name="description" rows="4"></textarea>
        </div>

        <div class="form-group">
          <label>Price (USD) *</label>
          <input type="number" name="price" step="0.01" min="0.99" required>
        </div>

        <div class="form-group">
          <label>Cover Image (JPG, PNG, GIF, WebP) *</label>
          <input type="file" name="cover" accept="image/*" required onchange="previewImage(this)">
          <img id="preview" class="preview" alt="Preview">
        </div>

        <div class="form-group">
          <label>Product File *</label>
          <input type="file" name="file" required>
          <small style="color: #999;">ZIP, PDF, audio files, or any downloadable content</small>
        </div>

        <button type="submit">Upload Product</button>
      </form>
    </div>
  </div>

  <script>
    function previewImage(input) {
      const preview = document.getElementById('preview');
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          preview.src = e.target.result;
          preview.style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
      }
    }
  </script>
</body>
</html>

