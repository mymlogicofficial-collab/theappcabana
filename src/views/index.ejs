<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The App Cabana - Apps, Music, Art</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0a0e27; color: #fff; }
    header { background: #1a1f3a; padding: 20px 40px; border-bottom: 1px solid #333; }
    header h1 { font-size: 28px; margin-bottom: 10px; }
    nav { display: flex; gap: 30px; }
    nav a { color: #ccc; text-decoration: none; transition: color 0.3s; }
    nav a:hover { color: #fff; }
    .hero { padding: 80px 40px; text-align: center; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .hero h2 { font-size: 48px; margin-bottom: 20px; }
    .hero p { font-size: 18px; margin-bottom: 30px; color: rgba(255,255,255,0.9); }
    .btn { display: inline-block; padding: 12px 30px; background: #667eea; color: #fff; text-decoration: none; border-radius: 8px; cursor: pointer; border: none; font-size: 16px; }
    .btn:hover { background: #764ba2; }
    .stats { display: flex; justify-content: center; gap: 60px; padding: 40px; }
    .stat { text-align: center; }
    .stat h3 { font-size: 32px; color: #667eea; margin-bottom: 10px; }
    .stat p { color: #aaa; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; padding: 40px; }
    .card { background: #1a1f3a; padding: 20px; border-radius: 8px; border: 1px solid #333; transition: transform 0.3s; }
    .card:hover { transform: translateY(-5px); }
    .card img { width: 100%; height: 180px; object-fit: cover; border-radius: 6px; margin-bottom: 15px; }
    .card h3 { margin-bottom: 10px; }
    .card p { color: #aaa; font-size: 14px; margin-bottom: 15px; }
    .price { color: #667eea; font-weight: bold; font-size: 18px; }
    footer { background: #1a1f3a; padding: 20px 40px; text-align: center; border-top: 1px solid #333; color: #aaa; }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>
  <header>
    <h1>🎭 The App Cabana</h1>
    <nav>
      <a href="/">Home</a>
      <a href="/shop/browse?type=app">Apps</a>
      <a href="/shop/browse?type=music">Music</a>
      <a href="/shop/browse?type=art">Art</a>
      <% if (user) { %>
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/auth/logout">Logout</a>
      <% } else { %>
        <a href="/auth/login">Login</a>
        <a href="/auth/register">Register</a>
      <% } %>
    </nav>
  </header>

  <div class="hero">
    <h2>Your Creative Store</h2>
    <p>Discover amazing apps, music, and art from independent creators</p>
    <a href="/shop/browse" class="btn">Explore Now</a>
  </div>

  <div class="stats">
    <div class="stat">
      <h3><%= stats.total_products %></h3>
      <p>Products Available</p>
    </div>
    <div class="stat">
      <h3><%= stats.total_downloads %></h3>
      <p>Total Downloads</p>
    </div>
    <div class="stat">
      <h3><%= stats.total_creators %></h3>
      <p>Active Creators</p>
    </div>
  </div>

  <h2 style="padding: 40px 40px 20px;">Featured</h2>
  <div class="grid">
    <% products.forEach(p => { %>
      <div class="card">
        <div style="background: #333; height: 180px; border-radius: 6px; margin-bottom: 15px;"></div>
        <h3><%= p.title %></h3>
        <p><%= p.description ? p.description.substring(0, 100) : 'No description' %></p>
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span class="price">$<%= (p.price_cents / 100).toFixed(2) %></span>
          <a href="/shop/product/<%= p.slug %>" class="btn" style="padding: 8px 15px; font-size: 14px;">View</a>
        </div>
      </div>
    <% }) %>
  </div>

  <footer>
    <p>&copy; 2026 The App Cabana. All rights reserved.</p>
  </footer>
</body>
</html>
