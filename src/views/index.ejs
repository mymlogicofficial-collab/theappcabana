<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The App Cabana - Apps, Music, Art</title>
</head>
<body>

  <!-- Replace this section with your actual EJS product loop -->
  <!-- Example of how your store items should look: -->
  <div class="product">
    <h3>Product 1</h3>
    <button class="previewBtn" data-song="YOUR_FIRST_SONG_URL.mp3">Preview Song</button>
  </div>

  <div class="product">
    <h3>Product 2</h3>
    <button class="previewBtn" data-song="YOUR_SECOND_SONG_URL.mp3">Preview Song</button>
  </div>
  <!-- End of store items -->


  <!-- ONE Global Audio Player placed at the bottom -->
  <audio id="mainAudioPlayer" preload="none"></audio>

  <!-- The script to handle all store buttons -->
  <script>
    const player = document.getElementById('mainAudioPlayer');
    let previewTimer;
    let activeBtn = null;

    document.querySelectorAll('.previewBtn').forEach(btn => {
      btn.addEventListener('click', function() {
        const songUrl = this.getAttribute('data-song');

        if (activeBtn === this && !player.paused) {
          player.pause();
          clearTimeout(previewTimer);
          this.innerText = "Preview Song";
          activeBtn = null;
          return;
        }

        if (activeBtn) activeBtn.innerText = "Preview Song";
        
        player.src = songUrl;
        activeBtn = this;
        this.innerText = "Loading...";

        player.onloadedmetadata = () => {
          const duration = player.duration;
          player.currentTime = duration > 20 ? (duration / 2) - 10 : 0;
          
          player.play();
          this.innerText = "Stop Preview";
          
          clearTimeout(previewTimer);
          previewTimer = setTimeout(() => {
            player.pause();
            this.innerText = "Preview Song";
            activeBtn = null;
          }, 20000);
        };
      });
    });
  </script>
</body>
</html>
