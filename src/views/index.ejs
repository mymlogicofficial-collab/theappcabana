<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The App Cabana - Digital Products & Merchandise</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0a0e27 0%, #1a1f3a 100%);
      color: #fff;
      line-height: 1.6;
    }
    
    .navbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 2rem;
      background: rgba(10, 14, 39, 0.95);
      border-bottom: 1px solid #333;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    
    .navbar a { color: #00ff88; text-decoration: none; margin: 0 1rem; font-weight: 500; }
    .navbar a:hover { color: #667eea; }
    
    header {
      text-align: center;
      padding: 60px 20px;
      background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
    }
    
    h1 { 
      font-size: 3.5rem;
      margin-bottom: 10px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .tagline { 
      font-size: 1.2rem;
      color: #aaa;
      margin-bottom: 30px;
    }
    
    .cta-buttons {
      display: flex;
      gap: 15px;
      justify-content: center;
      flex-wrap: wrap;
    }
    
    .btn {
      padding: 12px 30px;
      background: #667eea;
      color: #fff;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 1rem;
      text-decoration: none;
      display: inline-block;
      transition: 0.3s;
    }
    
    .btn:hover { background: #764ba2; }
    .btn-secondary { background: transparent; border: 2px solid #667eea; }
    .btn-secondary:hover { background: rgba(102, 126, 234, 0.1); }
    
    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 20px;
      margin: 40px 0;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }
    
    .stat-box {
      background: rgba(26, 31, 58, 0.8);
      padding: 20px;
      border-radius: 8px;
      border: 1px solid #333;
      text-align: center;
    }
    
    .stat-number { font-size: 2rem; color: #667eea; font-weight: bold; }
    .stat-label { color: #aaa; font-size: 0.9rem; margin-top: 5px; }
    
    .featured-section {
      max-width: 1200px;
      margin: 60px auto;
      padding: 0 20px;
    }
    
    .section-title {
      font-size: 2rem;
      margin-bottom: 30px;
      text-align: center;
    }
    
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 25px;
    }
    
    .product-card {
      background: rgba(26, 31, 58, 0.6);
      border: 1px solid #333;
      border-radius: 8px;
      overflow: hidden;
      transition: 0.3s;
    }
    
    .product-card:hover {
      transform: translateY(-5px);
      border-color: #667eea;
      background: rgba(26, 31, 58, 0.9);
    }
    
    .product-image {
      width: 100%;
      height: 200px;
      background: rgba(102, 126, 234, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #666;
      overflow: hidden;
      cursor: pointer;
    }
    
    .product-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .product-info {
      padding: 20px;
    }
    
    .product-title { font-weight: bold; margin-bottom: 8px; }
    .product-creator { color: #aaa; font-size: 0.9rem; margin-bottom: 10px; }
    .product-price { color: #667eea; font-weight: bold; font-size: 1.2rem; }
    .product-rating { color: #ffc107; font-size: 0.9rem; margin-top: 8px; }
    
    .preview-player {
      background: rgba(102, 126, 234, 0.1);
      padding: 12px;
      margin-top: 12px;
      border-radius: 6px;
      border: 1px solid #333;
    }
    
    .preview-label {
      font-size: 0.8rem;
      color: #aaa;
      margin-bottom: 8px;
      display: block;
    }
    
    audio {
      width: 100%;
      height: 30px;
    }
    
    footer {
      background: rgba(10, 14, 39, 0.95);
      border-top: 1px solid #333;
      padding: 40px 20px;
      margin-top: 60px;
    }
    
    .footer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 30px;
      max-width: 1200px;
      margin: 0 auto;
      margin-bottom: 30px;
    }
    
    .footer-section h3 { margin-bottom: 15px; color: #667eea; }
    .footer-section a { color: #00ff88; text-decoration: none; display: block; margin-bottom: 10px; font-size: 0.9rem; }
    .footer-section a:hover { color: #667eea; }
    
    .footer-bottom {
      text-align: center;
      padding-top: 20px;
      border-top: 1px solid #333;
      color: #aaa;
      font-size: 0.9rem;
    }
    
    .footer-bottom a { color: #667eea; text-decoration: none; }
    .footer-bottom a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>
  
  <header>
    <h1>The App Cabana</h1>
    <p class="tagline">Your creative marketplace for digital products & merchandise</p>
    <div class="cta-buttons">
      <a href="/shop/browse" class="btn">Browse Products</a>
      <a href="/auth/register" class="btn btn-secondary">Become a Seller</a>
    </div>
    
    <div class="stats">
      <div class="stat-box">
        <div class="stat-number"><%= stats.total_products %></div>
        <div class="stat-label">Products</div>
      </div>
      <div class="stat-box">
        <div class="stat-number"><%= stats.total_downloads %></div>
        <div class="stat-label">Downloads</div>
      </div>
      <div class="stat-box">
        <div class="stat-number"><%= stats.total_creators %></div>
        <div class="stat-label">Creators</div>
      </div>
    </div>
  </header>
  
  <section class="featured-section">
    <h2 class="section-title">Featured Products</h2>
    <div class="products-grid">
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
          <div class="product-card">
            <div class="product-image" onclick="window.location.href='/shop/product/<%= product.slug %>'">
              <% if (product.cover_url) { %>
                <img src="<%= product.cover_url %>" alt="<%= product.title %>">
              <% } else { %>
                <span style="color: #666;">No Image</span>
              <% } %>
            </div>
            <div class="product-info">
              <div class="product-title" onclick="window.location.href='/shop/product/<%= product.slug %>'" style="cursor: pointer;"><%= product.title.substring(0, 40) %><% if (product.title.length > 40) { %>...<% } %></div>
              <div class="product-creator">by <%= product.creator || 'Unknown' %></div>
              <div class="product-price">$<%= (product.price_cents / 100).toFixed(2) %></div>
              <div class="product-rating">⭐ <%= product.avg_rating ? product.avg_rating.toFixed(1) : 'N/A' %> (<%= product.review_count || 0 %> reviews)</div>
              
              <% if (product.type === 'music' && product.preview_url) { %>
                <div class="preview-player">
                  <span class="preview-label">🎵 Listen to preview</span>
                  <audio controls>
                    <source src="<%= product.preview_url %>" type="audio/mpeg">
                    Your browser does not support the audio element.
                  </audio>
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p style="grid-column: 1/-1; text-align: center; color: #aaa;">No products yet. Check back soon!</p>
      <% } %>
    </div>
  </section>
  
  <footer>
    <div class="footer-grid">
      <div class="footer-section">
        <h3>The App Cabana</h3>
        <p style="color: #aaa; margin-bottom: 15px;">Your creative marketplace for apps, music, and digital art.</p>
      </div>
      <div class="footer-section">
        <h3>Quick Links</h3>
        <a href="/shop/browse">Browse Products</a>
        <a href="/auth/register">Become a Seller</a>
        <a href="/">Home</a>
      </div>
      <div class="footer-section">
        <h3>Support</h3>
        <a href="/contact">Contact Us</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 MYM LOGIC LLC. All rights reserved.</p>
      <p style="margin-top: 10px;">The App Cabana - Supporting Independent Creators & <a href="/charity">The #7 Pencil Initiative</a></p>
    </div>
  </footer>
</body>
</html>

