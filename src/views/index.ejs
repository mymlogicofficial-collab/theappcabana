<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The App Cabana - Apps, Music, Art</title>
</head>
<body>

  <!-- Your song preview elements -->
  <audio id="songAudio" src="YOUR_SONG_FILE_URL.mp3" preload="metadata"></audio>
  <button id="previewBtn">Preview Song</button>

  <!-- The script to make the button work -->
  <script>
    const audio = document.getElementById('songAudio');
    const previewBtn = document.getElementById('previewBtn');
    let previewTimer;

    previewBtn.addEventListener('click', () => {
      if (!audio.paused) {
        audio.pause();
        clearTimeout(previewTimer);
        previewBtn.innerText = "Preview Song";
        return;
      }

      if (audio.readyState >= 1) { 
        playMidPreview();
      } else {
        audio.addEventListener('loadedmetadata', playMidPreview, { once: true });
      }
    });

    function playMidPreview() {
      const duration = audio.duration;
      
      if (duration > 20) {
        audio.currentTime = (duration / 2) - 10;
      } else {
        audio.currentTime = 0;
      }

      audio.play();
      previewBtn.innerText = "Stop Preview";

      previewTimer = setTimeout(() => {
        audio.pause();
        previewBtn.innerText = "Preview Song";
      }, 20000); 
    }
  </script>
</body>
</html>
