<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Browse - The App Cabana</title>
  <style>
    body { font-family: sans-serif; background: #0a0e27; color: #fff; }
    header { background: #1a1f3a; padding: 20px 40px; border-bottom: 1px solid #333; }
    .container { padding: 40px; }
    .filters { background: #1a1f3a; padding: 20px; border-radius: 8px; margin-bottom: 30px; border: 1px solid #333; }
    .filters form { display: flex; gap: 15px; }
    .filters input, .filters select { padding: 10px; background: #0a0e27; border: 1px solid #333; color: #fff; border-radius: 4px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; }
    .card { background: #1a1f3a; padding: 20px; border-radius: 8px; border: 1px solid #333; }
    .card h3 { margin-bottom: 10px; }
    .price { color: #667eea; font-weight: bold; }
    .btn { display: inline-block; padding: 8px 15px; background: #667eea; color: #fff; text-decoration: none; border-radius: 4px; margin-top: 10px; }
  </style>
</head>
<body>
  <header>
    <h1>🎭 The App Cabana</h1>
  </header>

  <div class="container">
    <h2>Browse</h2>
    <div class="filters">
      <form method="GET">
        <select name="type">
          <option value="">All Types</option>
          <option value="app" <%= filters.type === 'app' ? 'selected' : '' %>>Apps</option>
          <option value="music" <%= filters.type === 'music' ? 'selected' : '' %>>Music</option>
          <option value="art" <%= filters.type === 'art' ? 'selected' : '' %>>Art</option>
        </select>
        <input type="text" name="search" placeholder="Search..." value="<%= filters.search || '' %>">
        <select name="sort">
          <option value="">Featured</option>
          <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest</option>
          <option value="popular" <%= filters.sort === 'popular' ? 'selected' : '' %>>Most Downloaded</option>
          <option value="rating" <%= filters.sort === 'rating' ? 'selected' : '' %>>Top Rated</option>
        </select>
        <button type="submit" style="padding: 10px 20px; background: #667eea; border: none; color: #fff; cursor: pointer; border-radius: 4px;">Search</button>
      </form>
    </div>

    <div class="grid">
      <% products.forEach(p => { %>
        <div class="card">
          <h3><%= p.title %></h3>
          <p><%= p.description ? p.description.substring(0, 80) : 'No description' %>...</p>
          <div style="font-size: 12px; color: #aaa; margin: 10px 0;">
            by <%= p.creator %> | <%= p.download_count %> downloads
          </div>
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <span class="price">$<%= (p.price_cents / 100).toFixed(2) %></span>
            <a href="/shop/product/<%= p.slug %>" class="btn">View</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
