        <p class="description"><%= product.description %></p>
        
        <div id="download-section">
          <% if (product.price_cents === 0) { %>
            <form action="/api/download/<%= product.id %>" method="POST">
              <button type="submit" class="btn free-download">Download Now</button>
            </form>
          <% } else { %>
            <% if (user) { %>
              <form action="/api/purchase/<%= product.id %>" method="POST">
                <button type="submit" class="btn" id="pay-btn">Pay & Download - $<%= (product.price_cents / 100).toFixed(2) %></button>
              </form>
            <% } else { %>
              <p style="color: #aaa;"><a href="/auth/login" style="color: #667eea;">Login</a> to purchase</p>
            <% } %>
          <% } %>
        </div>
      </div>
    </div>

    <div class="reviews">
      <h2>Reviews</h2>
      
      <% if (user) { %>
        <form method="POST" action="/api/review/<%= product.id %>" style="background: #1a1f3a; padding: 20px; border-radius: 8px; margin-bottom: 30px;">
          <label>Rate this product:</label><br>
          <select name="rating" class="select">
            <option value="5">5 - Excellent</option>
            <option value="4">4 - Good</option>
            <option value="3">3 - OK</option>
            <option value="2">2 - Poor</option>
            <option value="1">1 - Terrible</option>
          </select>
          <textarea name="comment" placeholder="Share your thoughts..." rows="4"></textarea>
          <button type="submit" class="btn">Post Review</button>
        </form>
      <% } else { %>
        <p style="color: #aaa; margin-bottom: 20px;"><a href="/auth/login" style="color: #667eea;">Login</a> to leave a review</p>
      <% } %>

      <% if (reviews && reviews.length > 0) { %>
        <% reviews.forEach(r => { %>
          <div class="review">
            <div style="display: flex; justify-content: space-between;">
              <strong><%= r.display_name %></strong>
              <span class="stars">★ <%= r.rating %></span>
            </div>
            <p style="margin-top: 10px;"><%= r.comment %></p>
          </div>
        <% }) %>
      <% } else { %>
        <p style="color: #aaa;">No reviews yet. Be the first to review!</p>
      <% } %>
    </div>
  </div>
</body>
</html>

