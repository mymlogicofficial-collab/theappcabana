<body>
  <div class="container">
    <a href="/shop/browse" style="color: #667eea;">← Back to Browse</a>

    <div class="product-header">
      <div class="product-image <%= product.cover_url || product.file_path ? '' : 'empty' %>">
        <% if (product.cover_url) { %>
          <img src="<%= product.cover_url %>" alt="<%= product.title %>">
        <% } else if (product.preview_url) { %>
          <img src="<%= product.preview_url %>" alt="<%= product.title %>">
        <% } else if (product.file_path && (product.file_path.match(/\.(jpg|jpeg|png|gif|webp)$/i))) { %>
          <img src="<%= product.file_path %>" alt="<%= product.title %>">
        <% } else { %>
          No Image Available
        <% } %>
      </div>
      <div class="product-info">
        <h1><%= product.title %></h1>
        <div class="product-meta">
          By <strong><%= product.creator %></strong> | <%= product.download_count %> downloads
          <br><span class="stars">★ <%= product.avg_rating.toFixed(1) %> (<%= product.review_count %> reviews)</span>
        </div>
